#!/bin/bash
set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)
CHECK_API=false
CHECK_WEB=false

# Read refs being pushed from stdin (one line per ref: local_ref local_sha remote_ref remote_sha)
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # For a new remote branch, compare against the merge base with main
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "$local_sha")
    range="$base..$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  changed=$(git diff --name-only "$range" 2>/dev/null || true)

  echo "$changed" | grep -q "^api/" && CHECK_API=true
  echo "$changed" | grep -q "^web/" && CHECK_WEB=true
done

if ! $CHECK_API && ! $CHECK_WEB; then
  exit 0
fi

FAILED=false

if $CHECK_API; then
  echo ""
  echo "=== API: go build + vet ==="
  cd "$ROOT/api"
  if ! go build ./...; then FAILED=true; fi
  if ! go vet ./...;   then FAILED=true; fi

  echo ""
  echo "=== API: golangci-lint ==="
  if ! golangci-lint run ./...; then FAILED=true; fi
fi

if $CHECK_WEB; then
  echo ""
  echo "=== Web: typecheck + lint ==="
  cd "$ROOT/web"
  if ! npm run typecheck; then FAILED=true; fi
  if ! npm run lint;      then FAILED=true; fi
fi

echo ""
if $FAILED; then
  echo "Pre-push checks FAILED. Fix the issues above before pushing."
  exit 1
fi

echo "All pre-push checks passed."
