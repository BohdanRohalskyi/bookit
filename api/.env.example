# Environment: local, staging, prod
ENVIRONMENT=local

# Server configuration
API_PORT=8080
LOG_LEVEL=debug

# Database (required)
DATABASE_URL=postgres://bookit:bookit@localhost:5432/bookit?sslmode=disable

# JWT (required)
JWT_SECRET=local-dev-secret-change-in-production

# GCP (optional for local)
GCP_PROJECT=

# Frontend URL (for email links)
APP_URL=http://localhost:5173

# Mail configuration
# Provider: "smtp" (local with Mailpit) or "sendgrid" (production)
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@bookit.app

# SMTP settings (for local development with Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025

# SendGrid settings (for production)
SENDGRID_API_KEY=
