# API endpoint
# Docker: http://localhost:8080  |  Staging/prod: injected by CI from Secret Manager
VITE_API_URL=http://localhost:8080

# Cross-app session handoff (biz → consumer)
VITE_CONSUMER_URL=http://localhost:5173

# Firebase Remote Config — feature flags
# Leave blank for local dev: all flags default to false (see shared/src/features/flags.ts)
# Required for staging/prod: values injected from Secret Manager via CI
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
